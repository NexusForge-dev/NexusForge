<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusForge.ViewModels"
             x:Class="NexusForge.Views.Controls.DriverPanel"
             x:DataType="vm:DriverViewModel">

  <Border Background="#161B22"
          BorderBrush="#21262D"
          BorderThickness="1"
          CornerRadius="8">
    <StackPanel>

      <!-- ── Section header ── -->
      <Border BorderBrush="#21262D" BorderThickness="0,0,0,1" Padding="16,12,16,12">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Border Grid.Column="0" Background="#9E6A03" Width="3" CornerRadius="2"
                  VerticalAlignment="Stretch" Margin="0,0,10,0" />
          <TextBlock Grid.Column="1"
                     Text="DRIVER MANAGER"
                     FontSize="11" FontWeight="SemiBold"
                     Foreground="#E6EDF3" VerticalAlignment="Center" />
          <!-- Busy indicator -->
          <TextBlock Grid.Column="2"
                     Text="{Binding BusyMessage}"
                     Foreground="#8B949E" FontSize="11"
                     VerticalAlignment="Center"
                     IsVisible="{Binding IsBusy}" />
        </Grid>
      </Border>

      <!-- ── Status row ── -->
      <Border Padding="16,12,16,0">
        <Grid ColumnDefinitions="*,*">

          <!-- Left: device + status -->
          <StackPanel Grid.Column="0" Spacing="6">

            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Status" Foreground="#6E7681" FontSize="12" Width="65" />
              <StackPanel Orientation="Horizontal" Spacing="5">
                <Ellipse Width="8" Height="8"
                         Fill="{Binding StatusColor}"
                         VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{Binding StatusColor}"
                           FontSize="12" FontWeight="SemiBold" />
              </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Device" Foreground="#6E7681" FontSize="12" Width="65" />
              <TextBlock Text="{Binding DeviceName}"
                         Foreground="#C9D1D9" FontSize="12"
                         TextTrimming="CharacterEllipsis" MaxWidth="200" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="VID/PID" Foreground="#6E7681" FontSize="12" Width="65" />
              <TextBlock Text="{Binding VidPid}"
                         Foreground="#C9D1D9" FontSize="12"
                         FontFamily="Consolas,Courier New,monospace" />
            </StackPanel>

          </StackPanel>

          <!-- Right: version + type -->
          <StackPanel Grid.Column="1" Spacing="6">

            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Version" Foreground="#6E7681" FontSize="12" Width="65" />
              <TextBlock Text="{Binding VersionText}"
                         Foreground="#C9D1D9" FontSize="12" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Adapter" Foreground="#6E7681" FontSize="12" Width="65" />
              <TextBlock Text="CH347" Foreground="#C9D1D9" FontSize="12" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Type" Foreground="#6E7681" FontSize="12" Width="65" />
              <TextBlock Text="{Binding DriverType}"
                         Foreground="#C9D1D9" FontSize="12" />
            </StackPanel>

          </StackPanel>

        </Grid>
      </Border>

      <!-- ── Hint shown before first check ── -->
      <Border Padding="16,10,16,0"
              IsVisible="{Binding !IsChecked}">
        <Border Background="#1C2333" CornerRadius="6" Padding="12,8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="ℹ" Foreground="#58A6FF" FontSize="14" VerticalAlignment="Center" />
            <TextBlock Text="Press 'Check Driver' first to see the current driver status."
                       Foreground="#8B949E" FontSize="12" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </Border>

      <!-- ── Driver OK hint ── -->
      <Border Padding="16,10,16,0"
              IsVisible="{Binding IsDriverOk}">
        <Border Background="#0D2119" BorderBrush="#238636" BorderThickness="1"
                CornerRadius="6" Padding="12,8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="✓" Foreground="#3FB950" FontSize="14" VerticalAlignment="Center" />
            <TextBlock Foreground="#3FB950" FontSize="12" TextWrapping="Wrap">
              WCH CH347 driver is installed and working. Board detection and flashing are ready.
            </TextBlock>
          </StackPanel>
        </Border>
      </Border>

      <!-- ── Driver missing (device connected but no driver) ── -->
      <Border Padding="16,10,16,0"
              IsVisible="{Binding ShowDriverMissing}">
        <Border Background="#2D1A1A" BorderBrush="#6E1A1A" BorderThickness="1"
                CornerRadius="6" Padding="12,8">
          <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="!" Foreground="#F85149" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
              <TextBlock Foreground="#F85149" FontSize="12" FontWeight="SemiBold">
                CH347 driver is NOT installed. OpenOCD cannot communicate with the board.
              </TextBlock>
            </StackPanel>
            <TextBlock Foreground="#F85149" FontSize="12" TextWrapping="Wrap" Margin="22,0,0,0">
              Click 'Install Driver' to install the WCH CH347 driver automatically.
            </TextBlock>
          </StackPanel>
        </Border>
      </Border>

      <!-- ── Device not connected ── -->
      <Border Padding="16,10,16,0"
              IsVisible="{Binding ShowNotDetectedWarning}">
        <Border Background="#1C2333" BorderBrush="#30363D" BorderThickness="1"
                CornerRadius="6" Padding="12,8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="?" Foreground="#E3B341" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
            <TextBlock Foreground="#E3B341" FontSize="12" TextWrapping="Wrap">
              CH347 USB device not connected. Plug in the JTAG USB cable (the smaller USB port
              on the DMA board), then click Check Driver again.
            </TextBlock>
          </StackPanel>
        </Border>
      </Border>

      <!-- ── Loading indicator ── -->
      <Border Padding="16,8,16,0"
              IsVisible="{Binding IsBusy}">
        <StackPanel Spacing="6">
          <ProgressBar IsIndeterminate="True"
                       Foreground="#00D4AA"
                       Background="#21262D"
                       Height="4"
                       CornerRadius="2"
                       MinHeight="4" />
          <TextBlock Text="{Binding BusyMessage}"
                     Foreground="#00D4AA" FontSize="12" FontWeight="SemiBold"
                     HorizontalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- ── Action buttons ── -->
      <Border Padding="16,12,16,14">
        <Grid ColumnDefinitions="*,*,*" HorizontalAlignment="Stretch">

          <!-- Check Driver -->
          <Button Grid.Column="0"
                  Classes="primary"
                  Command="{Binding CheckDriverCommand}"
                  IsEnabled="{Binding !IsBusy}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Margin="0,0,6,0">
            Check Driver
          </Button>

          <!-- Install CH347 Driver -->
          <Button Grid.Column="1"
                  Classes="teal-outline"
                  Command="{Binding InstallDriverCommand}"
                  IsEnabled="{Binding !IsBusy}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Margin="0,0,6,0">
            Install Driver
          </Button>

          <!-- Uninstall CH347 Driver -->
          <Button Grid.Column="2"
                  Classes="danger-outline"
                  Command="{Binding UninstallDriverCommand}"
                  IsEnabled="{Binding !IsBusy}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center">
            Uninstall Driver
          </Button>

        </Grid>
      </Border>

    </StackPanel>
  </Border>
</UserControl>
