<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusForge.ViewModels"
             x:Class="NexusForge.Views.Controls.HeaderControl"
             x:DataType="vm:MainViewModel">

  <Border Background="#161B22"
          BorderBrush="#21262D"
          BorderThickness="0,0,0,1">
    <Grid ColumnDefinitions="Auto,*,Auto" Margin="20,14,20,14">

      <!-- Logo badge -->
      <Border Grid.Column="0"
              Background="#00D4AA"
              CornerRadius="8"
              Width="40" Height="40"
              VerticalAlignment="Center"
              Margin="0,0,14,0">
        <TextBlock Text="N" Foreground="#0A0D14"
                   FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
      </Border>

      <!-- Title + tagline -->
      <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
        <TextBlock Text="NEXUSFORGE"
                   FontSize="19" FontWeight="Bold"
                   Foreground="#E6EDF3" />
        <TextBlock Text="DMA FPGA Management Tool"
                   FontSize="11" Foreground="#6E7681" />
      </StackPanel>

      <!-- Version badge -->
      <Border Grid.Column="2"
              Background="#21262D"
              BorderBrush="#30363D"
              BorderThickness="1"
              CornerRadius="20"
              Padding="12,5"
              VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="5">
          <Ellipse Width="6" Height="6" Fill="#3FB950" VerticalAlignment="Center"/>
          <TextBlock Text="v1.1.5" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold" />
        </StackPanel>
      </Border>

    </Grid>

    <!-- Teal accent line at bottom -->
    <Border.Background>
      <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Color="#1C2333" Offset="0"/>
        <GradientStop Color="#161B22" Offset="1"/>
      </LinearGradientBrush>
    </Border.Background>

  </Border>
</UserControl>
