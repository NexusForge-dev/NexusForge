<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusForge.ViewModels"
             x:Class="NexusForge.Views.Controls.DmaTestPanel"
             x:DataType="vm:DmaTestViewModel">

  <StackPanel Spacing="6">

    <!-- ═══ FTDI DRIVER MANAGEMENT ═══ -->
    <Border Background="#161B22" BorderBrush="#21262D" BorderThickness="1" CornerRadius="8">
      <StackPanel>

        <!-- Header -->
        <Border BorderBrush="#21262D" BorderThickness="0,0,0,1" Padding="16,10,16,10">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <Border Grid.Column="0" Background="#58A6FF" Width="3" CornerRadius="2"
                    VerticalAlignment="Stretch" Margin="0,0,10,0" />
            <TextBlock Grid.Column="1" Text="FTDI FT601 DRIVER (DATA PORT)"
                       FontSize="11" FontWeight="SemiBold" Foreground="#E6EDF3"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="2" Text="{Binding FtdiBusyMessage}"
                       Foreground="#8B949E" FontSize="11" VerticalAlignment="Center"
                       IsVisible="{Binding IsFtdiBusy}" />
          </Grid>
        </Border>

        <!-- Status -->
        <Border Padding="16,8,16,0">
          <Grid ColumnDefinitions="*,*">
            <StackPanel Grid.Column="0" Spacing="4">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Status" Foreground="#6E7681" FontSize="12" Width="60" />
                <Ellipse Width="8" Height="8" Fill="{Binding FtdiStatusColor}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding FtdiStatusText}" Foreground="{Binding FtdiStatusColor}"
                           FontSize="12" FontWeight="SemiBold" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Device" Foreground="#6E7681" FontSize="12" Width="60" />
                <TextBlock Text="{Binding FtdiDeviceName}" Foreground="#C9D1D9" FontSize="12" />
              </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="4">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Version" Foreground="#6E7681" FontSize="12" Width="60" />
                <TextBlock Text="{Binding FtdiVersionText}" Foreground="#C9D1D9" FontSize="12" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Type" Foreground="#6E7681" FontSize="12" Width="60" />
                <TextBlock Text="{Binding FtdiDriverType}" Foreground="#C9D1D9" FontSize="12" />
              </StackPanel>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Hints -->
        <Border Padding="16,6,16,0" IsVisible="{Binding !IsFtdiChecked}">
          <Border Background="#1C2333" CornerRadius="6" Padding="10,6">
            <TextBlock Text="Press 'Check Driver' to verify FTDI FT601 status."
                       Foreground="#8B949E" FontSize="11" />
          </Border>
        </Border>
        <Border Padding="16,6,16,0" IsVisible="{Binding IsFtdiDriverOk}">
          <Border Background="#0D2119" BorderBrush="#238636" BorderThickness="1"
                  CornerRadius="6" Padding="10,6">
            <TextBlock Text="FTDI FT601 driver installed. DMA data path ready."
                       Foreground="#3FB950" FontSize="11" />
          </Border>
        </Border>
        <Border Padding="16,6,16,0" IsVisible="{Binding ShowFtdiDriverMissing}">
          <Border Background="#2D1A1A" BorderBrush="#6E1A1A" BorderThickness="1"
                  CornerRadius="6" Padding="10,6">
            <TextBlock Text="FTDI driver missing. Click Install Driver."
                       Foreground="#F85149" FontSize="11" />
          </Border>
        </Border>

        <!-- Loading -->
        <Border Padding="16,6,16,0" IsVisible="{Binding IsFtdiBusy}">
          <ProgressBar IsIndeterminate="True" Foreground="#58A6FF" Background="#21262D"
                       Height="4" CornerRadius="2" MinHeight="4" />
        </Border>

        <!-- Buttons -->
        <Border Padding="16,8,16,10">
          <Grid ColumnDefinitions="*,*,*">
            <Button Grid.Column="0" Classes="primary" Command="{Binding CheckFtdiCommand}"
                    IsEnabled="{Binding !IsFtdiBusy}" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center" Margin="0,0,4,0">Check Driver</Button>
            <Button Grid.Column="1" Classes="teal-outline" Command="{Binding InstallFtdiCommand}"
                    IsEnabled="{Binding !IsFtdiBusy}" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center" Margin="0,0,4,0">Install Driver</Button>
            <Button Grid.Column="2" Classes="danger-outline" Command="{Binding UninstallFtdiCommand}"
                    IsEnabled="{Binding !IsFtdiBusy}" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center">Uninstall</Button>
          </Grid>
        </Border>

      </StackPanel>
    </Border>

    <!-- ═══ DMA SPEED TEST ═══ -->
    <Border Background="#161B22" BorderBrush="#21262D" BorderThickness="1" CornerRadius="8">
      <StackPanel>

        <!-- Header -->
        <Border BorderBrush="#21262D" BorderThickness="0,0,0,1" Padding="16,10,16,10">
          <Grid ColumnDefinitions="Auto,*,Auto,Auto">
            <Border Grid.Column="0" Background="#E3B341" Width="3" CornerRadius="2"
                    VerticalAlignment="Stretch" Margin="0,0,10,0" />
            <TextBlock Grid.Column="1" Text="DMA SPEED TEST"
                       FontSize="11" FontWeight="SemiBold" Foreground="#E6EDF3"
                       VerticalAlignment="Center" />

            <!-- Test type selector -->
            <ComboBox Grid.Column="2"
                      ItemsSource="{Binding TestTypes}"
                      SelectedIndex="{Binding SelectedTestType}"
                      Background="#21262D" Foreground="#C9D1D9"
                      BorderBrush="#30363D" BorderThickness="1"
                      FontSize="11" CornerRadius="4"
                      Padding="8,4" Margin="0,0,6,0"
                      MinWidth="120"
                      VerticalAlignment="Center" />

            <Button Grid.Column="3" Classes="primary" Background="#E3B341"
                    Command="{Binding RunSpeedTestCommand}"
                    IsEnabled="{Binding !IsTesting}" Padding="14,5">
              Run Test
            </Button>
          </Grid>
        </Border>

        <!-- Test progress -->
        <Border Padding="16,8,16,0" IsVisible="{Binding IsTesting}">
          <StackPanel Spacing="4">
            <ProgressBar IsIndeterminate="False" Value="{Binding TestPercentage}"
                         Minimum="0" Maximum="100" Foreground="#E3B341"
                         Background="#21262D" Height="4" CornerRadius="2" MinHeight="4" />
            <TextBlock Text="{Binding TestMessage}" Foreground="#E3B341" FontSize="11"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>

        <!-- Results Row 1: Status / Rating / RPS / Avg Read -->
        <Border Padding="16,8,16,2">
          <Grid ColumnDefinitions="*,*,*,*">
            <StackPanel Grid.Column="0" Spacing="2">
              <TextBlock Text="Status" Foreground="#6E7681" FontSize="10" FontWeight="SemiBold" />
              <TextBlock Text="{Binding TestStatus}" Foreground="#C9D1D9" FontSize="13" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="2">
              <TextBlock Text="Rating" Foreground="#6E7681" FontSize="10" FontWeight="SemiBold" />
              <TextBlock Text="{Binding TestRating}" Foreground="#E3B341" FontSize="13" FontWeight="Bold" />
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="2">
              <TextBlock Text="RPS" Foreground="#6E7681" FontSize="10" FontWeight="SemiBold" />
              <TextBlock Text="{Binding TestRps}" Foreground="#00D4AA" FontSize="13" FontWeight="SemiBold"
                         FontFamily="Consolas,Courier New,monospace" />
            </StackPanel>
            <StackPanel Grid.Column="3" Spacing="2">
              <TextBlock Text="Avg Read" Foreground="#6E7681" FontSize="10" FontWeight="SemiBold" />
              <TextBlock Text="{Binding TestLatency}" Foreground="#C9D1D9" FontSize="13"
                         FontFamily="Consolas,Courier New,monospace" />
            </StackPanel>
          </Grid>
        </Border>

        <!-- Results Row 2: Throughput / Min Read / Max Read / Failed -->
        <Border Padding="16,2,16,6" IsVisible="{Binding HasResults}">
          <Grid ColumnDefinitions="*,*,*,*">
            <StackPanel Grid.Column="0" Spacing="2">
              <TextBlock Text="Throughput" Foreground="#6E7681" FontSize="10" FontWeight="SemiBold" />
              <TextBlock Text="{Binding TestThroughput}" Foreground="#58A6FF" FontSize="13" FontWeight="SemiBold"
                         FontFamily="Consolas,Courier New,monospace" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="2">
              <TextBlock Text="Min Read" Foreground="#6E7681" FontSize="10" FontWeight="SemiBold" />
              <TextBlock Text="{Binding TestMinRead}" Foreground="#C9D1D9" FontSize="13"
                         FontFamily="Consolas,Courier New,monospace" />
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="2">
              <TextBlock Text="Max Read" Foreground="#6E7681" FontSize="10" FontWeight="SemiBold" />
              <TextBlock Text="{Binding TestMaxRead}" Foreground="#C9D1D9" FontSize="13"
                         FontFamily="Consolas,Courier New,monospace" />
            </StackPanel>
            <StackPanel Grid.Column="3" Spacing="2">
              <TextBlock Text="Failed" Foreground="#6E7681" FontSize="10" FontWeight="SemiBold" />
              <TextBlock Text="{Binding TestFailed}" Foreground="#F85149" FontSize="13"
                         FontFamily="Consolas,Courier New,monospace" />
            </StackPanel>
          </Grid>
        </Border>

        <!-- Bottom padding -->
        <Border Height="2" />

      </StackPanel>
    </Border>

  </StackPanel>
</UserControl>
