<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusForge.ViewModels"
             xmlns:svc="using:NexusForge.Services"
             x:Class="NexusForge.Views.Controls.StatusLogPanel"
             x:DataType="vm:MainViewModel">

  <Border Background="#161B22"
          BorderBrush="#21262D"
          BorderThickness="1"
          CornerRadius="8">
    <DockPanel>

      <!-- ── Section header ── -->
      <Border DockPanel.Dock="Top"
              BorderBrush="#21262D" BorderThickness="0,0,0,1"
              Padding="16,12,16,12">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">

          <!-- Left accent + title -->
          <Border Grid.Column="0" Background="#E3B341" Width="3" CornerRadius="2"
                  VerticalAlignment="Stretch" Margin="0,0,10,0" />
          <TextBlock Grid.Column="1"
                     Text="STATUS LOG"
                     FontSize="11" FontWeight="SemiBold"
                     Foreground="#E6EDF3"
                     VerticalAlignment="Center" />

          <!-- Entry count badge -->
          <Border Grid.Column="2"
                  Background="#21262D" CornerRadius="10"
                  Padding="8,3" Margin="0,0,8,0"
                  VerticalAlignment="Center">
            <TextBlock Text="{Binding LogCount}"
                       Foreground="#8B949E" FontSize="10" />
          </Border>

          <!-- Copy All button -->
          <Button Grid.Column="3"
                  Classes="ghost"
                  Command="{Binding CopyLogCommand}"
                  Margin="0,0,4,0">
            Copy All
          </Button>

          <!-- Clear button -->
          <Button Grid.Column="4"
                  Classes="ghost"
                  Command="{Binding ClearLogCommand}">
            Clear
          </Button>

        </Grid>
      </Border>

      <!-- ── Log list ── -->
      <Border Background="#0D1117" Margin="1,0,1,1" CornerRadius="0,0,7,7">
        <ListBox x:Name="LogList"
                 ItemsSource="{Binding LogEntries}"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="8,6,8,6"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">

          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding"                    Value="0,1"/>
              <Setter Property="Background"                 Value="Transparent"/>
              <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
              <Setter Property="Margin"                     Value="0"/>
            </Style>
            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
              <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
              <Setter Property="Background" Value="Transparent"/>
            </Style>
          </ListBox.Styles>

          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="svc:LogEntry">
              <Grid ColumnDefinitions="Auto,Auto,*" Margin="0,1,0,1">

                <!-- Timestamp -->
                <TextBlock Grid.Column="0"
                           Text="{Binding Timestamp, StringFormat='[{0:HH:mm:ss}]'}"
                           Foreground="#484F58"
                           FontSize="11"
                           FontFamily="Consolas,Courier New,monospace"
                           VerticalAlignment="Top"
                           Margin="0,0,6,0"/>

                <!-- Level badge -->
                <Border Grid.Column="1"
                        CornerRadius="3" Padding="4,1"
                        Margin="0,0,8,0" VerticalAlignment="Top">
                  <Border.Background>
                    <SolidColorBrush Color="#21262D"/>
                  </Border.Background>
                  <TextBlock Text="{Binding Level}"
                             Foreground="{Binding Level, Converter={x:Static vm:LogLevelToColorConverter.Instance}}"
                             FontSize="10" FontWeight="SemiBold"
                             FontFamily="Consolas,Courier New,monospace"/>
                </Border>

                <!-- Message -->
                <TextBlock Grid.Column="2"
                           Text="{Binding Message}"
                           Foreground="#8B949E"
                           FontSize="11"
                           FontFamily="Consolas,Courier New,monospace"
                           TextWrapping="NoWrap"
                           VerticalAlignment="Top"/>

              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>

        </ListBox>
      </Border>

    </DockPanel>
  </Border>
</UserControl>
