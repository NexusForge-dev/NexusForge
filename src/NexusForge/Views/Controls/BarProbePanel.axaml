<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusForge.ViewModels"
             x:Class="NexusForge.Views.Controls.BarProbePanel"
             x:DataType="vm:BarProbeViewModel">

  <StackPanel Spacing="6">

    <!-- ═══ INPUTS ═══ -->
    <Border Background="#161B22" BorderBrush="#21262D" BorderThickness="1" CornerRadius="8">
      <StackPanel>

        <!-- Header -->
        <Border BorderBrush="#21262D" BorderThickness="0,0,0,1" Padding="16,10">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <Border Grid.Column="0" Background="#A371F7" Width="3" CornerRadius="2"
                    VerticalAlignment="Stretch" Margin="0,0,10,0" />
            <TextBlock Grid.Column="1" Text="BAR PROBE  ·  Read FPGA BAR memory via DMA"
                       FontSize="11" FontWeight="SemiBold" Foreground="#E6EDF3"
                       VerticalAlignment="Center" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <Ellipse Width="7" Height="7" Fill="{Binding StatusColor}" VerticalAlignment="Center" />
              <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}"
                         FontSize="11" />
            </StackPanel>
          </Grid>
        </Border>

        <!-- Inputs grid -->
        <Border Padding="16,12,16,8">
          <Grid ColumnDefinitions="Auto,*,Auto,140,Auto,80,Auto,80" RowDefinitions="Auto,8,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Address (hex):"
                       Foreground="#6E7681" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                     Text="{Binding AddressHex}"
                     Watermark="hex address (e.g. 100000 = 1MB mark in RAM)"
                     Background="#0D1117" Foreground="#C9D1D9" BorderBrush="#30363D"
                     FontFamily="Consolas,Courier New,monospace" FontSize="12"
                     Padding="8,5" CornerRadius="4" />
            <TextBlock Grid.Row="0" Grid.Column="4" Text="Length:"
                       Foreground="#6E7681" FontSize="12" VerticalAlignment="Center" Margin="12,0,8,0" />
            <TextBox  Grid.Row="0" Grid.Column="5" Text="{Binding Length}"
                      Background="#0D1117" Foreground="#C9D1D9" BorderBrush="#30363D"
                      FontFamily="Consolas,Courier New,monospace" FontSize="12"
                      Padding="8,5" CornerRadius="4" />
            <TextBlock Grid.Row="0" Grid.Column="6" Text="Period(ms):"
                       Foreground="#6E7681" FontSize="12" VerticalAlignment="Center" Margin="12,0,8,0" />
            <TextBox  Grid.Row="0" Grid.Column="7" Text="{Binding PeriodMs}"
                      Background="#0D1117" Foreground="#C9D1D9" BorderBrush="#30363D"
                      FontFamily="Consolas,Courier New,monospace" FontSize="12"
                      Padding="8,5" CornerRadius="4" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Log file:"
                       Foreground="#6E7681" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="7"
                     Text="{Binding LogFile}"
                     Watermark="(auto: %TEMP%\barprobe_YYYYMMDD_HHMMSS.log)"
                     Background="#0D1117" Foreground="#C9D1D9" BorderBrush="#30363D"
                     FontFamily="Consolas,Courier New,monospace" FontSize="12"
                     Padding="8,5" CornerRadius="4" />
          </Grid>
        </Border>

        <!-- Action buttons (custom address) -->
        <Border Padding="16,0,16,8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="primary"
                    Content="Read Once"
                    Command="{Binding ReadOnceCommand}" />
            <Button Classes="teal-outline"
                    Content="Start Polling"
                    Command="{Binding StartPollCommand}" />
            <Button Classes="danger-outline"
                    Content="Stop Polling"
                    Command="{Binding StopPollCommand}" />
            <TextBlock VerticalAlignment="Center" Margin="12,0,0,0"
                       Foreground="#8B949E" FontSize="11">
              <Run Text="Samples logged:" />
              <Run Text="{Binding PollSamples}" Foreground="#C9D1D9" />
            </TextBlock>
          </StackPanel>
        </Border>

        <!-- Helper buttons (FPGA-specific + diagnostics) -->
        <Border Padding="16,0,16,12">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="ghost"
                    Content="Test FPGA Link"
                    Command="{Binding TestConnectionCommand}"
                    ToolTip.Tip="Reads system RAM at 0x100000 to verify FTDI/leechcore/FPGA chain works" />
            <Button Classes="ghost"
                    Content="Read DMA Config Space"
                    Command="{Binding ReadFpgaCfgCommand}"
                    ToolTip.Tip="Reads the FPGA's PCIe config space via Type 0 cfg TLPs (works regardless of P2P)" />
            <Button Classes="ghost"
                    Content="List PCIe Devices"
                    Command="{Binding EnumerateDevicesCommand}"
                    ToolTip.Tip="Lists all PCIe devices and their BAR addresses (via Windows WMI)" />
          </StackPanel>
        </Border>

      </StackPanel>
    </Border>

    <!-- ═══ PCIe DEVICE LIST ═══ -->
    <Border Background="#161B22" BorderBrush="#21262D" BorderThickness="1" CornerRadius="8"
            IsVisible="{Binding DeviceList.Count}">
      <StackPanel>
        <Border BorderBrush="#21262D" BorderThickness="0,0,0,1" Padding="16,10">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Background="#58A6FF" Width="3" CornerRadius="2" />
            <TextBlock Text="PCIe DEVICES + BAR ADDRESSES" FontSize="11" FontWeight="SemiBold" Foreground="#E6EDF3" />
          </StackPanel>
        </Border>
        <Border Padding="16,8" MaxHeight="200">
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding DeviceList}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}"
                             FontFamily="Consolas,Courier New,monospace"
                             FontSize="11"
                             Foreground="#C9D1D9"
                             Margin="0,1" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>
      </StackPanel>
    </Border>

    <!-- ═══ LAST READ OUTPUT ═══ -->
    <Border Background="#161B22" BorderBrush="#21262D" BorderThickness="1" CornerRadius="8">
      <StackPanel>
        <Border BorderBrush="#21262D" BorderThickness="0,0,0,1" Padding="16,10">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Background="#3FB950" Width="3" CornerRadius="2" />
            <TextBlock Text="LAST READ" FontSize="11" FontWeight="SemiBold" Foreground="#E6EDF3" />
          </StackPanel>
        </Border>

        <Border Padding="16,12">
          <Grid ColumnDefinitions="*,*">
            <StackPanel Grid.Column="0" Spacing="4">
              <TextBlock Text="Raw bytes (hex):" Foreground="#6E7681" FontSize="11" />
              <Border Background="#0D1117" CornerRadius="4" Padding="10,8">
                <TextBlock Text="{Binding LastReadHex}"
                           FontFamily="Consolas,Courier New,monospace"
                           FontSize="11"
                           Foreground="#C9D1D9"
                           TextWrapping="Wrap" />
              </Border>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="4" Margin="12,0,0,0">
              <TextBlock Text="As 32-bit DWords:" Foreground="#6E7681" FontSize="11" />
              <Border Background="#0D1117" CornerRadius="4" Padding="10,8">
                <TextBlock Text="{Binding LastReadParsed}"
                           FontFamily="Consolas,Courier New,monospace"
                           FontSize="11"
                           Foreground="#C9D1D9"
                           TextWrapping="NoWrap" />
              </Border>
            </StackPanel>
          </Grid>
        </Border>
      </StackPanel>
    </Border>

  </StackPanel>
</UserControl>
