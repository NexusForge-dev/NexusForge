п»ї<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexusForge.ViewModels"
        xmlns:ctrl="using:NexusForge.Views.Controls"
        x:Class="NexusForge.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="NexusForge v1.1.19"
        Width="950" Height="960"
        MinWidth="950" MinHeight="960"
        MaxWidth="950" MaxHeight="960"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        Foreground="#E6EDF3">

  <Window.Styles>

    <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Primary button ГўвЂќв‚¬ГўвЂќв‚¬ -->
    <Style Selector="Button.primary">
      <Setter Property="Background"      Value="#00D4AA"/>
      <Setter Property="Foreground"      Value="#0A0D14"/>
      <Setter Property="FontWeight"      Value="SemiBold"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="CornerRadius"    Value="6"/>
      <Setter Property="Padding"         Value="16,7"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.primary:pointerover">
      <Setter Property="Opacity" Value="0.85"/>
    </Style>
    <Style Selector="Button.primary:pressed">
      <Setter Property="Opacity" Value="0.70"/>
    </Style>

    <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Teal outline ГўвЂќв‚¬ГўвЂќв‚¬ -->
    <Style Selector="Button.teal-outline">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="Foreground"      Value="#00D4AA"/>
      <Setter Property="BorderBrush"     Value="#00D4AA"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius"    Value="6"/>
      <Setter Property="Padding"         Value="12,5"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.teal-outline:pointerover">
      <Setter Property="Opacity" Value="0.75"/>
    </Style>

    <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Danger outline ГўвЂќв‚¬ГўвЂќв‚¬ -->
    <Style Selector="Button.danger-outline">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="Foreground"      Value="#F85149"/>
      <Setter Property="BorderBrush"     Value="#F85149"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius"    Value="6"/>
      <Setter Property="Padding"         Value="16,7"/>
      <Setter Property="FontWeight"      Value="SemiBold"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.danger-outline:pointerover">
      <Setter Property="Opacity" Value="0.75"/>
    </Style>

    <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Ghost ГўвЂќв‚¬ГўвЂќв‚¬ -->
    <Style Selector="Button.ghost">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="Foreground"      Value="#6E7681"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius"    Value="5"/>
      <Setter Property="Padding"         Value="8,4"/>
      <Setter Property="FontSize"        Value="11"/>
      <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.ghost:pointerover">
      <Setter Property="Opacity" Value="0.70"/>
    </Style>

    <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Disabled ГўвЂќв‚¬ГўвЂќв‚¬ -->
    <Style Selector="Button:disabled">
      <Setter Property="Opacity" Value="0.32"/>
      <Setter Property="Cursor"  Value="Arrow"/>
    </Style>

    <!-- ГўвЂќв‚¬ГўвЂќв‚¬ CheckBox ГўвЂќв‚¬ГўвЂќв‚¬ -->
    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="#8B949E"/>
      <Setter Property="FontSize"   Value="12"/>
    </Style>

    <!-- ГўвЂќв‚¬ГўвЂќв‚¬ ProgressBar ГўвЂќв‚¬ГўвЂќв‚¬ -->
    <Style Selector="ProgressBar">
      <Setter Property="Foreground"   Value="#00D4AA"/>
      <Setter Property="Background"   Value="#21262D"/>
      <Setter Property="Height"       Value="6"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="MinHeight"    Value="6"/>
    </Style>

    <!-- ГўвЂќв‚¬ГўвЂќв‚¬ TabControl chrome ГўвЂќв‚¬ГўвЂќв‚¬ -->
    <Style Selector="TabControl">
      <Setter Property="Background"   Value="Transparent"/>
      <Setter Property="Padding"      Value="0"/>
    </Style>
    <Style Selector="TabItem">
      <Setter Property="Background"   Value="Transparent"/>
      <Setter Property="Foreground"   Value="#6E7681"/>
      <Setter Property="FontSize"     Value="12"/>
      <Setter Property="FontWeight"   Value="SemiBold"/>
      <Setter Property="Padding"      Value="16,10"/>
      <Setter Property="Cursor"       Value="Hand"/>
      <Setter Property="Margin"       Value="0"/>
      <Setter Property="BorderThickness" Value="0,0,0,2"/>
      <Setter Property="BorderBrush"     Value="Transparent"/>
    </Style>
    <Style Selector="TabItem:selected">
      <Setter Property="Foreground"   Value="#E6EDF3"/>
      <Setter Property="BorderBrush"  Value="#00D4AA"/>
    </Style>
    <Style Selector="TabItem:pointerover">
      <Setter Property="Foreground"   Value="#C9D1D9"/>
    </Style>

  </Window.Styles>

  <!--
    DockPanel layout Гўв‚¬вЂќ items dock in order:
      1. Header       ГўвЂ вЂ™ Top    (fixed height)
      2. StatusBar    ГўвЂ вЂ™ Bottom (fixed height)
      3. StatusLog    ГўвЂ вЂ™ Bottom (fixed 200px)
      4. TabControl   ГўвЂ вЂ™ Fill   (takes ALL remaining space)
    This guarantees the log never pushes tab content up.
  -->
  <DockPanel LastChildFill="True">

    <!-- ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ 1. HEADER Гўв‚¬вЂќ docked top ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ -->
    <ctrl:HeaderControl DockPanel.Dock="Top" DataContext="{Binding}" />

    <!-- ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ 2. STATUS BAR Гўв‚¬вЂќ docked bottom ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ -->
    <Border DockPanel.Dock="Bottom"
            Background="#161B22"
            BorderBrush="#21262D"
            BorderThickness="0,1,0,0"
            Padding="20,7">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="{Binding StatusBarText}"
                   Foreground="#484F58" FontSize="11"
                   VerticalAlignment="Center" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <Ellipse Width="7" Height="7" Fill="#3FB950" VerticalAlignment="Center"/>
          <TextBlock Text="System Ready" Foreground="#484F58" FontSize="11" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ 3. STATUS LOG Гўв‚¬вЂќ docked bottom, FIXED 200px height ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ -->
    <ctrl:StatusLogPanel DockPanel.Dock="Bottom"
                         DataContext="{Binding}"
                         Height="200"
                         Margin="12,4,12,8" />

    <!-- ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ 4. TAB CONTROL Гўв‚¬вЂќ fills all remaining space ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ -->
    <TabControl Background="Transparent" Margin="0">

      <!-- ГўвЂўВђГўвЂўВђГўвЂўВђ Tab 1: BOARD & FLASH ГўвЂўВђГўвЂўВђГўвЂўВђ -->
      <TabItem Header="  BOARD &amp; FLASH  ">
        <StackPanel>
          <ctrl:BoardInfoPanel DataContext="{Binding BoardInfo}" Margin="12,8,12,0" />
          <ctrl:FlashPanel     DataContext="{Binding Flash}"     Margin="12,6,12,6"  />
        </StackPanel>
      </TabItem>

      <!-- ГўвЂўВђГўвЂўВђГўвЂўВђ Tab 2: DRIVER MANAGER ГўвЂўВђГўвЂўВђГўвЂўВђ -->
      <TabItem Header="  DRIVER MANAGER  ">
        <StackPanel>
          <ctrl:DriverPanel DataContext="{Binding Driver}" Margin="12,8,12,6" />

            <!-- Info card -->
            <Border Background="#161B22"
                    BorderBrush="#21262D"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="12,0,12,8"
                    Padding="16,14">
              <StackPanel Spacing="10">

                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Border Background="#9E6A03" Width="3" CornerRadius="2" />
                  <TextBlock Text="HOW IT WORKS"
                             FontSize="11" FontWeight="SemiBold"
                             Foreground="#E6EDF3" />
                </StackPanel>

                <StackPanel Spacing="6">
                  <TextBlock Foreground="#8B949E" FontSize="12" TextWrapping="Wrap">
                    NexusForge uses OpenOCD to communicate with DMA boards via the
                    CH347 USB-JTAG chip. The WCH CH347 driver MUST be installed for this to work.
                    Without it, OpenOCD cannot access the JTAG interface.
                  </TextBlock>
                  <TextBlock Foreground="#8B949E" FontSize="12" TextWrapping="Wrap">
                    Install: First tries Windows Update (pnputil /scan-devices), then attempts
                    to download the WCH installer directly. If all else fails, opens the WCH
                    product page for manual download.
                  </TextBlock>
                  <Border Background="#1C2333" CornerRadius="6" Padding="12,8" Margin="0,4,0,0">
                    <StackPanel Spacing="4">
                      <TextBlock Text="Official WCH resources (verified April 2024):"
                                 Foreground="#6E7681" FontSize="11" FontWeight="SemiBold" />
                      <TextBlock Foreground="#58A6FF" FontSize="11"
                                 FontFamily="Consolas,Courier New,monospace">
                        https://github.com/WCHSoftGroup/ch347
                      </TextBlock>
                      <TextBlock Text="Release: CH347_OpenOCD_Release Гўв‚¬вЂќ contains OpenOCD binary and CH347FPGATool"
                                 Foreground="#6E7681" FontSize="11" />
                    </StackPanel>
                  </Border>
                </StackPanel>

              </StackPanel>
            </Border>
          </StackPanel>
      </TabItem>

      <!-- ГўвЂўВђГўвЂўВђГўвЂўВђ Tab 4: BAR PROBE ГўвЂўВђГўвЂўВђГўвЂўВђ -->
      <TabItem Header="  BAR PROBE  ">
        <StackPanel>
          <ctrl:BarProbePanel DataContext="{Binding BarProbe}" Margin="12,8,12,6" />

          <!-- Info card -->
          <Border Background="#161B22"
                  BorderBrush="#21262D"
                  BorderThickness="1"
                  CornerRadius="8"
                  Margin="12,0,12,8"
                  Padding="16,14">
            <StackPanel Spacing="10">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Border Background="#A371F7" Width="3" CornerRadius="2" />
                <TextBlock Text="ABOUT BAR PROBE"
                           FontSize="11" FontWeight="SemiBold" Foreground="#E6EDF3" />
              </StackPanel>
              <StackPanel Spacing="6">
                <TextBlock Foreground="#8B949E" FontSize="12" TextWrapping="Wrap">
                  Reads physical memory through the FPGA's DMA engine. Useful for
                  inspecting host RAM, other PCIe devices' BAR memory (NIC, GPU,
                  storage controllers), and anything the OS exposes in the physical
                  address space.
                </TextBlock>
                <TextBlock Foreground="#8B949E" FontSize="12" TextWrapping="Wrap">
                  <Run FontWeight="SemiBold" Foreground="#E3B341">Limitation:</Run>
                  The DMA card cannot read its OWN BAR memory via this path on
                  most chipsets (PCIe self-loopback / peer-to-peer routing is
                  usually blocked). Use "Read DMA Config Space" instead Гўв‚¬вЂќ it uses
                  Type 0 config TLPs which the root complex always routes correctly.
                </TextBlock>
                <TextBlock Foreground="#8B949E" FontSize="12" TextWrapping="Wrap">
                  Helpers:
                  <LineBreak/>
                  Гўв‚¬Вў <Run FontWeight="SemiBold">Test FPGA Link</Run> Гўв‚¬вЂќ reads system RAM at 0x100000, confirms FTDI + leechcore + FPGA chain works
                  <LineBreak/>
                  Гўв‚¬Вў <Run FontWeight="SemiBold">Read DMA Config Space</Run> Гўв‚¬вЂќ reads the FPGA's own PCIe config space (vendor/device IDs, BARs, capabilities, DSN)
                  <LineBreak/>
                  Гўв‚¬Вў <Run FontWeight="SemiBold">List PCIe Devices</Run> Гўв‚¬вЂќ enumerates host PCIe devices + their BAR address ranges so you can pick a target without hunting in Device Manager
                </TextBlock>
                <TextBlock Foreground="#8B949E" FontSize="12" TextWrapping="Wrap">
                  Polling: appends a timestamped hex dump to the log file every
                  Period(ms). When the FPGA loses connection (target PC freezes /
                  reboots / cable unplugged), the poll loop detects consecutive
                  failures and stops cleanly. The log file is preserved on this PC.
                </TextBlock>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </TabItem>

      <!-- ГўвЂўВђГўвЂўВђГўвЂўВђ Tab 3: DMA TESTING ГўвЂўВђГўвЂўВђГўвЂўВђ -->
      <TabItem Header="  DMA TESTING  ">
        <StackPanel>
          <ctrl:DmaTestPanel DataContext="{Binding DmaTest}" Margin="12,8,12,6" />

          <!-- Info card -->
          <Border Background="#161B22"
                  BorderBrush="#21262D"
                  BorderThickness="1"
                  CornerRadius="8"
                  Margin="12,0,12,8"
                  Padding="16,14">
            <StackPanel Spacing="10">

              <StackPanel Orientation="Horizontal" Spacing="8">
                <Border Background="#E3B341" Width="3" CornerRadius="2" />
                <TextBlock Text="ABOUT DMA SPEED TESTING"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#E6EDF3" />
              </StackPanel>

              <StackPanel Spacing="6">
                <TextBlock Foreground="#8B949E" FontSize="12" TextWrapping="Wrap">
                  NexusForge tests DMA read performance through the FPGA board's FT601 data port.
                  The FTDI SuperSpeed driver must be installed and the board must have PCILeech-compatible
                  firmware loaded (flash + cold reboot required).
                </TextBlock>
                <TextBlock Foreground="#8B949E" FontSize="12" TextWrapping="Wrap">
                  Full Test: process lookup + latency (4KB reads) + throughput (16MB reads).
                  Latency Test: 30 seconds of 4KB random reads Гўв‚¬вЂќ measures RPS and per-read timing.
                  Throughput Test: 15 seconds of 16MB sequential reads Гўв‚¬вЂќ measures sustained MB/s.
                  Stress Test: long-duration soak (default 5 min, configurable 1-60 min) mixing
                  4KB and 16MB reads, tracking failures and the longest consecutive-failure streak.
                  Reports PASS if the DMA path stays stable for the whole duration.
                </TextBlock>
                <Border Background="#1C2333" CornerRadius="6" Padding="12,8" Margin="0,4,0,0">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Rating Scale:" Foreground="#6E7681" FontSize="11" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                      <TextBlock Foreground="#3FB950" FontSize="11" FontFamily="Consolas,Courier New,monospace">PERFECT</TextBlock>
                      <TextBlock Foreground="#58A6FF" FontSize="11" FontFamily="Consolas,Courier New,monospace">EXCELLENT</TextBlock>
                      <TextBlock Foreground="#E3B341" FontSize="11" FontFamily="Consolas,Courier New,monospace">GOOD</TextBlock>
                      <TextBlock Foreground="#D29922" FontSize="11" FontFamily="Consolas,Courier New,monospace">ACCEPTABLE</TextBlock>
                      <TextBlock Foreground="#F85149" FontSize="11" FontFamily="Consolas,Courier New,monospace">FAIL</TextBlock>
                    </StackPanel>
                    <TextBlock Foreground="#6E7681" FontSize="11" TextWrapping="Wrap">
                      Latency: PERFECT 18K+ RPS | EXCELLENT 6K+ | GOOD 4K+ | ACCEPTABLE 3K+
                    </TextBlock>
                    <TextBlock Foreground="#6E7681" FontSize="11" TextWrapping="Wrap">
                      Throughput: PERFECT 600+ MB/s | EXCELLENT 200+ | GOOD 150+ | ACCEPTABLE 100+
                    </TextBlock>
                  </StackPanel>
                </Border>
              </StackPanel>

            </StackPanel>
          </Border>
        </StackPanel>
      </TabItem>

    </TabControl>

  </DockPanel>
</Window>
